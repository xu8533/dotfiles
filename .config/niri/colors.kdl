layout {
    focus-ring {
        active-color "#8b4f25"
        inactive-color "#84746a"
        urgent-color   "#ba1a1a"
    }

    border {
        active-color   "#8b4f25"
        inactive-color "#84746a"
        urgent-color   "#ba1a1a"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#8b4f25"
        inactive-color "#84746a"
        urgent-color   "#ba1a1a"
    }

    insert-hint {
        color "#8b4f2580"
    }
}

